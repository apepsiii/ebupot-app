# ============================================================
#  Environment Variables — e-Bupot Portal
#  Salin file ini menjadi ".env" lalu sesuaikan nilainya.
#  File ".env" JANGAN di-commit (sudah di-gitignore).
# ============================================================

# Mode aplikasi: development | production
APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Domain publik untuk URL QR & Share Link (tanpa http/https). Contoh: ebupot.domainanda.com
SERVER_DOMAIN=localhost:8080
# Scheme: http | https | kosong=auto-detect dari request/proxy
# Di production (behind Nginx), biarkan kosong agar auto-detect https dari X-Forwarded-Proto
SERVER_SCHEME=

# Database
DB_PATH=data/ebupot.db

# Upload
UPLOAD_MAX_SIZE_MB=100

# QR Code
QR_RECOVERY_LEVEL=high
QR_SIZE=512

# Session (WAJIB ganti di production dengan string random panjang)
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_MAX_AGE=86400
